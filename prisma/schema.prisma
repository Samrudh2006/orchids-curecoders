datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  password   String
  role       String      @default("Analyst")
  workspaces Workspace[]
  createdAt  DateTime    @default(now())
}

model Workspace {
  id        String         @id @default(uuid())
  name      String
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  queries   SearchQuery[]
  files     UploadedFile[]
  createdAt DateTime       @default(now())
}

model SearchQuery {
  id          String        @id @default(uuid())
  prompt      String
  synthesis   String
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agents      String        // JSON string array of agents used
  results     AgentResult[]
  createdAt   DateTime      @default(now())
}

model AgentResult {
  id         String      @id @default(uuid())
  queryId    String
  query      SearchQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  agentName  String
  resultJson String      // JSON string of agent data
  status     String      // DONE, FAILED, RUNNING
  createdAt  DateTime    @default(now())
}

model UploadedFile {
  id          String          @id @default(uuid())
  filename    String
  filepath    String
  sizeBytes   Int
  filetype    String
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunks      DocumentChunk[]
  createdAt   DateTime        @default(now())
}

model DocumentChunk {
  id        String       @id @default(uuid())
  fileId    String
  file      UploadedFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  chunkText String
  embedding String       // Float array represented as JSON string
  createdAt DateTime     @default(now())
}

model Bookmark {
  id           String   @id @default(uuid())
  userId       String
  title        String
  query        String
  summary      String
  agentResults String   // JSON string
  tags         String   @default("[]") // JSON string array of tags
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SharedWorkspace {
  id         String    @id @default(uuid())
  ownerId    String
  sharedWith String    // JSON string array of emails
  permission String    @default("Viewer") // Viewer, Commenter, Editor
  query      String
  result     String    // JSON string of synthesis + agent results
  createdAt  DateTime  @default(now())
  comments   Comment[]
}

model Comment {
  id                String          @id @default(uuid())
  sharedWorkspaceId String
  sharedWorkspace   SharedWorkspace @relation(fields: [sharedWorkspaceId], references: [id], onDelete: Cascade)
  userId            String
  userEmail         String
  content           String
  createdAt         DateTime        @default(now())
}

model TeamChatMessage {
  id        String   @id @default(uuid())
  userId    String
  userEmail String
  userName  String
  content   String
  createdAt DateTime @default(now())
}
